<root BTCPP_format="4">
  <BehaviorTree ID="MainTree">

    <Sequence name="CircleTrajectory">

      <!-- Generate circular waypoints -->
      <ComputePathToPose
        goal="{goal}"
        path="{path}"
        planner_id="GridBased"/>

      <!-- Follow the path -->
      <FollowPath
          path="{path}"
          controller_id="FollowPath"/>

    </Sequence>

  </BehaviorTree>
</root>